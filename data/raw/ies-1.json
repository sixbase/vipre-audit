  "product": "IES",
  "screens": [
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-allow-list-2026-06-17-08_06_06.png",
      "screen_label": "Allow List",
      "module": "Settings",
      "layout_notes": "Dark navy fixed left sidebar (~220px) + light gray body. Dark navy top bar carries a 'New Rule' primary blue button. Page title 'Allow List' with a small shield glyph rendered large/bold at top of content. White search bar spanning full width with a blue magnifier search button on the right. Below: a white table card with a disabled gray 'Delete' bulk-action button top-right, header row in light gray, and a 'No data' / 'Found 0 matches' empty state. House style is a dense enterprise admin look distinct from a modern token-based DS; mixes very large page title typography with small table type."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-audit-logs-2026-06-17-08_08_11.png",
      "screen_label": "Audit Logs",
      "module": "Admins",
      "layout_notes": "Same dark sidebar shell. Content is a single full-width white table card titled 'Audit events' with a 'TIME' date-range chip top-right and an 'Add column +' control. Dense, many-row data table (Timestamp/User/Action/Target/Error columns). Bottom shows 'Found 320 matches' and numbered pagination (1 2 3 4 5 ... ) with prev/next arrows. Classic enterprise data-grid era."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-detection-settings-2026-06-17-08_06_18.png",
      "screen_label": "Detection Settings",
      "module": "Settings",
      "layout_notes": "Settings form layout: white card on light gray body holding stacked sections ('Sandbox', 'Microsoft 365 Allow List') each with a bold heading, helper text, a bulleted list of file extensions, and an iOS-style pill toggle switch ('Enable ...'). Toggles appear off (gray). Calm form-centric layout."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-email-configuration-2026-06-17-08_04_49.png",
      "screen_label": "Email Configuration (source picker / empty)",
      "module": "Settings",
      "layout_notes": "Onboarding/selector screen. Centered prompt 'Select a source below to configure and add to IES.' with three large equal white selection cards (Microsoft 365 / IMAP / Google Workspace), each with a brand glyph and bold label, subtle rounded corners and shadow. Distinct centered marketing-style layout vs the data-grid screens."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-email-configuration-2026-06-17-08_17_25.png",
      "screen_label": "Email Configuration (configured sources)",
      "module": "Settings",
      "layout_notes": "Populated state of Email Configuration. Top bar has three blue primary buttons (Add IMAP / Add M365 / Add Google Workspace) each with an icon. Body shows two side-by-side white data-cards per connected source, each with brand glyph + name, green 'CONNECTED' status badge, a refresh icon and kebab menu, key/value meta rows (Type/Mode/Source ID), two inline metric numbers with tiny red down-arrows ('Emails in the last week / last 24 hours'), and a small sparkline/area mini-chart with Jun 11-17 axis. Mixed card+metric+chart composition."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-home-2026-06-17-08_02_47.png",
      "screen_label": "Dashboard (empty / get started)",
      "module": "Overview",
      "layout_notes": "Empty-state dashboard. Large white card filling body with a faint dotted/graph-paper background, a centered line-art envelope+gears illustration, heading 'Start your account configuration', a paragraph of muted body copy, and a single blue 'Get started!' primary button. Friendly onboarding empty state."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-home-2026-06-17-08_16_38.png",
      "screen_label": "Dashboard (populated)",
      "module": "Overview",
      "layout_notes": "Dense analytics dashboard. Top row of KPI tiles separated by vertical dividers (Emails 27, Internal/External 3, Attachments 3, Users 163, Data 17, Clean 11, plus more) with small colored icons. 'TIME' date chip top-right. 'Emails vs Threats' wide combo chart (bars + area lines) with a legend (Emails/Phishing/Suspicious/Malware). Row of small white list-cards (Top Attackers, Top Threat Tactics, Top Targets, Top Targeted Groups) with mini tables. Second row: a treemap ('Top Threat Types' Malware/Spam/Unrated), horizontal bar 'Threat Severity' and 'Threat Vectors' meters, and a donut/bubble 'Top Engines by Detections'. Full-width 'Attack Origins' world map with plotted points and + zoom control. Heaviest, most chart-rich screen; busy enterprise BI aesthetic."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-ies-link-isolation-2026-06-17-08_06_30.png",
      "screen_label": "Link Isolation",
      "module": "Settings",
      "layout_notes": "Settings screen with a horizontal tab strip (URL Filter Configuration / Allowed IPs/Domains / Denied IPs/Domains / Templates). Body is a long form: master 'Enable Link Isolation' toggle, sub-sections (Click-time Protection, URL Rewriting) with radio groups (Block / Click Through), a numbered 'EMAIL TIMEOUT (SECONDS)' input, and multiple toggles. A blue 'Save Changes' button bottom-right. Tabbed form pattern not seen on other screens."
    }
  ],
