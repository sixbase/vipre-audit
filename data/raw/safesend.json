  "screens": [
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-dashboard-2026-06-17-08_10_00.png",
      "screen_label": "Dashboard",
      "module": "Overview",
      "layout_notes": "Dark navy left sidebar + dark navy topbar, but white/light content canvas. Content area uses light cards on near-white background. KPI row of bordered outline tiles, a combined bar+axis chart, three 'Top ___' list cards, two treemap-style distribution panels. This is the 'light content' design era of the app."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-assignments-2026-06-17-08_11_28.png",
      "screen_label": "Assignments",
      "module": "Manage",
      "layout_notes": "Light content canvas. Single white card containing a draggable priority list with drag-handle dots, avatar+name rows, small count pills, right-aligned policy link, and an X remove icon per row. Solid filled 'Add Assignment' button in topbar (different button style than the outline KPI era)."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-events-explorer-2026-06-17-08_10_39.png",
      "screen_label": "Events Explorer",
      "module": "Analytics",
      "layout_notes": "FULLY DARK theme content area (dark navy table on dark background) — distinctly different design era/skin from the light Dashboard/Policies pages. Left faceted filter rail, dense data-heavy log table with colored status text, many inline icons, badge counts, bottom pagination with rows-per-page select. Looks like a separate, denser 'explorer' library."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-policies-2026-06-17-08_12_05 (1).png",
      "screen_label": "Policies (duplicate capture)",
      "module": "Manage",
      "layout_notes": "Near-identical duplicate of the other Policies capture. Light content canvas, borderless table with link-styled policy names, info icons, a 'Default' badge, Clone text-link action + X icon, numbered pill pagination."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-policies-2026-06-17-08_12_05.png",
      "screen_label": "Policies",
      "module": "Manage",
      "layout_notes": "Light content canvas. Borderless/ruled table, blue link policy names with leading info (i) icon, light-blue 'Default' badge, rounded search input top-right, 'Clone' text link + X icon row actions, numbered pill pagination with chevron arrows. Solid 'Add Policy' button in topbar."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-reports-2026-06-17-08_10_22.png",
      "screen_label": "Reports",
      "module": "Overview",
      "layout_notes": "FULLY DARK theme content area like Events Explorer — different era from light pages. Top filter date/select row, three chart cards (two donut/pie, one line trend), then a dense dark table with pill status badges and attachment icons, numbered pagination. Multi-color pie palette stands out vs. rest of app."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-rulesets-2026-06-17-08_12_40.png",
      "screen_label": "Rulesets",
      "module": "Manage",
      "layout_notes": "Light content canvas, matches Policies styling. Sortable table (caret on Name column), blue link names, numeric columns, date column, 'Clone' link + X row actions, numbered pill pagination. Solid 'Add Ruleset' button in topbar."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-sensitive-data-explorer-2026-06-17-08_11_13.png",
      "screen_label": "Sensitive Data Explorer",
      "module": "Analytics",
      "layout_notes": "Light content canvas but with an 'explorer' flavor: Rules/Keywords tab toggle, search with solid dark search-button, a row of bordered KPI tiles with circular icon chips, then a table with sortable column headers + caret affordances, inline warning triangle icons, a gear/column-config icon, and a 'Rows 25' select + arrow pagination. Mix of the light-card era and the explorer-table era."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-settings-2026-06-17-08_13_09.png",
      "screen_label": "Settings",
      "module": "Set Up",
      "layout_notes": "Light content canvas, form/marketing-document style. Green success banner, status key-value block, a logo card with 'Edit logo' outline button, and two 'manifest configuration' option blocks each with a blue solid 'Download' button. Long-form copy, different rhythm than data tables."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-strings-2026-06-17-08_12_56.png",
      "screen_label": "Strings",
      "module": "Manage",
      "layout_notes": "FULLY DARK theme content area — another dark/explorer-skinned page. Very dense three-column editable string table (key / default text / English text) with per-row edit pencil icons, alternating subtle row shading, green 'Publish/Save' style button in topbar. High-density admin grid."
    },
    {
      "file": "screencapture-ices-dev-portal-electric-net-safesend-admin-users-explorer-2026-06-17-08_11_01.png",
      "screen_label": "User Explorer",
      "module": "Analytics",
      "layout_notes": "DARK theme content area like Events Explorer. Row of KPI tiles up top (incl. a 'Default Policy' info tile), then dense user table with colored circular avatar initials, numeric counts, 'Default Policy' link cells, relative + absolute timestamp 'Last Activity', gear column-config icon, rows-per-page select pagination."
    }
